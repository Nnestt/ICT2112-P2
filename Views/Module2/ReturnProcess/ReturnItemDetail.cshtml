@model List<ProRental.Domain.Entities.Returnitem>
@using ProRental.Domain.Enums
@using ProRental.Domain.Entities

@{
    ViewData["Title"] = "Return Item Details";
    var request        = ViewBag.Request as Returnrequest;
    var damageReportMap = ViewBag.DamageReportMap as Dictionary<int, Damagereport?> 
                          ?? new Dictionary<int, Damagereport?>();
}

<div class="container py-4">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="ReturnProcessing" asp-action="DisplayReturnRequests">Return Requests</a>
            </li>
            <li class="breadcrumb-item active">Request #@request?.GetReturnRequestId()</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-box-seam me-2"></i>Return Request #@request?.GetReturnRequestId()
            </h2>
            <p class="text-muted mb-0">
                Order #@request?.GetOrderId()
                &nbsp;·&nbsp; Customer #@request?.GetCustomerId()
                &nbsp;·&nbsp; @request?.GetRequestDate().ToString("dd MMM yyyy")
            </p>
        </div>
        @if (request?.GetStatus() == ReturnRequestStatus.COMPLETED)
        {
            <span class="badge bg-success fs-6 px-3 py-2">Completed</span>
        }
        else
        {
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">Processing</span>
        }
    </div>

    @if (TempData["Message"] is string message)
    {
        <div class="alert alert-info alert-dismissible fade show">
            @message
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <p>No items found for this return request.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                var s = item.GetStatus();
                var statusColor = s switch
                {
                    ReturnItemStatus.DAMAGE_INSPECTION   => "warning",
                    ReturnItemStatus.REPAIRING           => "danger",
                    ReturnItemStatus.SERVICING           => "info",
                    ReturnItemStatus.CLEANING            => "primary",
                    ReturnItemStatus.RETURN_TO_INVENTORY => "success",
                    _ => "secondary"
                };
                var statusLabel = s switch
                {
                    ReturnItemStatus.DAMAGE_INSPECTION   => "Damage Inspection",
                    ReturnItemStatus.REPAIRING           => "Repairing",
                    ReturnItemStatus.SERVICING           => "Servicing",
                    ReturnItemStatus.CLEANING            => "Cleaning",
                    ReturnItemStatus.RETURN_TO_INVENTORY => "Returned to Inventory",
                    _ => s.ToString()
                };
                int currentIdx = (int)s;
                string[] stepLabels = { "Inspect", "Repair", "Service", "Clean", "Done" };
                string[] stepColors = { "warning", "danger", "info", "primary", "success" };

                damageReportMap.TryGetValue(item.GetReturnItemId(), out Damagereport? dmgReport);
                bool isCompleted = s == ReturnItemStatus.RETURN_TO_INVENTORY;

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-@statusColor border-opacity-50 shadow-sm">
                        <div class="card-header bg-@statusColor bg-opacity-10">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="fw-semibold">Item #@item.GetReturnItemId()</span>
                                <span class="badge bg-@statusColor @(statusColor == "warning" ? "text-dark" : "")">
                                    @statusLabel
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="mb-1 text-muted small">
                                <i class="bi bi-box me-1"></i>Inventory Item ID: <strong>@item.GetInventoryItemId()</strong>
                            </p>
                            @if (item.GetCompletionDate().HasValue)
                            {
                                <p class="mb-2 text-muted small">
                                    <i class="bi bi-calendar-check me-1"></i>
                                    Completed: @item.GetCompletionDate()!.Value.ToString("dd MMM yyyy")
                                </p>
                            }

                            <!-- Progress bar -->
                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Progress</small>
                                <div class="d-flex gap-1">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        var dot     = i < currentIdx ? "success" : (i == currentIdx ? stepColors[i] : "light");
                                        var dotText = i <= currentIdx ? "text-white" : "text-muted";
                                        <span class="badge bg-@dot @dotText flex-fill text-center"
                                              style="font-size:0.6rem">@stepLabels[i]</span>
                                    }
                                </div>
                            </div>

                            <!-- Damage report section (only for completed items) -->
                            @if (isCompleted)
                            {
                                <hr class="my-2" />
                                @if (dmgReport != null)
                                {
                                    <div class="small">
                                        <div class="fw-semibold text-danger mb-1">
                                            <i class="bi bi-file-earmark-medical me-1"></i>Damage Report
                                        </div>
                                        <div class="mb-1">
                                            <span class="text-muted">Description:</span>
                                            <span class="ms-1">@dmgReport.GetDescription()</span>
                                        </div>
                                        <div class="d-flex gap-3 mb-1">
                                            <span>
                                                <span class="text-muted">Severity:</span>
                                                @{
                                                    var sevColor = dmgReport.GetSeverity() switch {
                                                        "Minor"    => "success",
                                                        "Moderate" => "warning",
                                                        "Severe"   => "danger",
                                                        "Critical" => "dark",
                                                        _ => "secondary"
                                                    };
                                                }
                                                <span class="badge bg-@sevColor ms-1">@dmgReport.GetSeverity()</span>
                                            </span>
                                            <span>
                                                <span class="text-muted">Cost:</span>
                                                <span class="ms-1 fw-semibold">$@dmgReport.GetRepairCost()?.ToString("F2")</span>
                                            </span>
                                        </div>
                                        <div class="text-muted">
                                            Reported: @dmgReport.GetReportDate().ToString("dd MMM yyyy")
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="small text-muted">
                                        <i class="bi bi-check-circle text-success me-1"></i>No Damage
                                    </div>
                                }
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            @if (!isCompleted)
                            {
                                <a asp-controller="ReturnProcessing"
                                   asp-action="ReturnForm"
                                   asp-route-itemId="@item.GetReturnItemId()"
                                   class="btn btn-sm btn-primary w-100">
                                    <i class="bi bi-pencil-square me-1"></i>Process Item
                                </a>
                            }
                            else if (dmgReport != null)
                            {
                                <!-- Download damage report — follows iDamageReportQuery.DownloadDamageReport -->
                                <a asp-controller="ReturnProcessing"
                                   asp-action="ExportDamageReport"
                                   asp-route-itemId="@item.GetReturnItemId()"
                                   class="btn btn-sm btn-outline-danger w-100">
                                    <i class="bi bi-download me-1"></i>Download Damage Report
                                </a>
                            }
                            else
                            {
                                <div class="text-center text-muted small py-1">
                                    <i class="bi bi-check-circle text-success me-1"></i>No report to download
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
