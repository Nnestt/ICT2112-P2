@model List<ProRental.Domain.Module2.P2_2.Entities.Supplier>

@{
    ViewData["Title"] = "Trusted Supplier Registry";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">@ViewData["Title"]</h2>
    <a class="btn btn-success" asp-controller="SupplierRegistryPage" asp-action="Create">
        <i class="bi bi-plus-circle me-2"></i>Add Supplier
    </a>
</div>

@if (TempData["Success"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Details</th>
            <th>CreditPeriod</th>
            <th>AvgTurnaroundTime</th>
            <th>Category</th>
            <th>IsVerified</th>
            <th>VettingResult</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model is null || Model.Count == 0)
        {
            <tr>
                <td colspan="9" class="text-muted">No suppliers found.</td>
            </tr>
        }
        else
        {
            foreach (var supplier in Model)
            {
                var categoryBadge = supplier.SupplierCategory switch
                {
                    ProRental.Domain.Enums.SupplierCategory.LONGCREDITPERIOD => "bg-primary",
                    ProRental.Domain.Enums.SupplierCategory.QUICKTURNAROUNDTIME => "bg-info",
                    _ => "bg-warning"
                };

                var verifiedBadge = supplier.IsVerified ? "bg-success" : "bg-warning";

                var vettingBadge = supplier.VettingResult switch
                {
                    ProRental.Domain.Enums.VettingDecision.APPROVED => "bg-success",
                    ProRental.Domain.Enums.VettingDecision.REJECTED => "bg-danger",
                    _ => "bg-secondary"
                };

                <tr>
                    <td>@supplier.SupplierID</td>
                    <td>@supplier.Name</td>
                    <td>@supplier.Details</td>
                    <td>@supplier.CreditPeriod</td>
                    <td>@supplier.AvgTurnaroundTime</td>
                    <td>
                        <span class="badge @categoryBadge text-dark">@supplier.SupplierCategory</span>
                    </td>
                    <td>
                        <span class="badge @verifiedBadge">@((supplier.IsVerified) ? "Verified" : "Unverified")</span>
                    </td>
                    <td>
                        <span class="badge @vettingBadge">@supplier.VettingResult</span>
                    </td>
                    <td class="text-end">
                        <div class="btn-group" role="group">
                            <a class="btn btn-sm btn-primary" asp-controller="SupplierRegistryPage" asp-action="Edit" asp-route-id="@supplier.SupplierID">
                                <i class="bi bi-pencil-square me-1"></i>Edit
                            </a>
                            <form asp-controller="SupplierRegistryPage" asp-action="Delete" asp-route-id="@supplier.SupplierID" method="post" onsubmit="return confirm('Delete this supplier?');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

