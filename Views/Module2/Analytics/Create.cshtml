@model IEnumerable<ProRental.Interfaces.TransactionLogDto>
@{
    ViewData["Title"] = "New Analytics";
    var today = DateTime.Now.ToString("yyyy-MM-dd");
    var logs  = Model.ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-plus-circle me-2" style="color:#0d6efd;"></i>New Analytics</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post" asp-action="Create">
                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Analytics Type</label>
                        <select name="analyticsType" id="analyticsType" class="form-select" onchange="updateTitle()">
                            <option value="DAILY">Daily</option>
                            <option value="SUPTREND">Supplier Trend</option>
                            <option value="PRODTREND">Product Trend</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input type="date" name="startDate" id="startDate" class="form-control"
                               value="@today" onchange="updateTitle()" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">End Date</label>
                        <input type="date" name="endDate" id="endDate" class="form-control"
                               value="@today" onchange="updateTitle()" required />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Reference Name / Label</label>
                        <input type="text" name="refPrimaryName" id="refPrimaryName" class="form-control"
                               placeholder="e.g. Daily, Supplier ABC, Canon R5..." required />
                        <div class="form-text">For Daily: use "Daily". For trends: use supplier or product name.</div>
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>Create Analytics
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Available Transaction Logs -->
    <div class="card mt-4 shadow-sm">
        <div class="card-header fw-semibold">
            <i class="bi bi-list-ul me-2"></i>Available Transaction Logs (@logs.Count total)
            <small class="text-muted ms-2">— logs within your selected date range will be included automatically</small>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Log ID</th><th>Type</th><th>Created At</th><th>Summary</th></tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        var badge = log.LogType switch {
                            "LOAN"           => "bg-primary",
                            "RETURN"         => "bg-warning text-dark",
                            "PURCHASE_ORDER" => "bg-success",
                            "RENTAL_ORDER"   => "bg-info text-dark",
                            "CLEARANCE"      => "bg-secondary",
                            _                => "bg-dark"
                        };
                        <tr>
                            <td>#@log.LogID</td>
                            <td><span class="badge @badge">@log.LogType</span></td>
                            <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-muted small">@log.Summary</td>
                        </tr>
                    }
                    @if (!logs.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No transaction logs found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function updateTitle() {
    var type  = document.getElementById('analyticsType').value;
    var start = document.getElementById('startDate').value;
    var end   = document.getElementById('endDate').value;
    var ref   = document.getElementById('refPrimaryName');

    var dateLabel = start === end ? start : start + ' to ' + end;
    var typeLabel = type === 'DAILY' ? 'Daily' : '';

    if (type === 'DAILY') {
        ref.placeholder = 'Daily — ' + dateLabel;
        if (ref.value === '' || ref.value.startsWith('Daily')) {
            ref.value = 'Daily — ' + dateLabel;
        }
    } else {
        ref.placeholder = type === 'SUPTREND' ? 'Supplier name...' : 'Product name...';
    }
}
updateTitle();
</script>
