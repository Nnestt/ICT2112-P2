@if (Model.RequestId <= 0)
{
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white">
            <h5 class="mb-0">
                <i class="bi bi-table me-2"></i>
                Purchase Order Requests
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Requests != null && Model.Requests.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Request ID</th>
                                <th>Requested By</th>
                                <th>Created At</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.Requests)
                            {
                                <tr>
                                    <td class="fw-semibold">@request.RequestId</td>
                                    <td>@request.RequestedBy</td>
                                    <td>@(request.CreatedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                    <td>
                                        <span class="badge bg-secondary">@request.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="PurchaseOrderPage" asp-action="PurchaseOrderView"
                                               asp-route-reqId="@request.RequestId" class="btn btn-success btn-sm">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @* else
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-circle me-2"></i>No replenishment requests found.
                </div>
            } *@
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Request ID</th>
                                <th>Requested By</th>
                                <th>Created At</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">101</td>
                                <td>Alice Tan</td>
                                <td>@DateTime.Now.AddDays(-2).ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge bg-secondary">Pending</span></td>
                                <td class="text-center">
                                    <button class="btn btn-success btn-sm" disabled>
                                        <i class="bi bi-eye me-1"></i>View
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold">102</td>
                                <td>Ben Lim</td>
                                <td>@DateTime.Now.AddDays(-1).ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge bg-success">Approved</span></td>
                                <td class="text-center">
                                    <a asp-controller="PurchaseOrderPage"    asp-action="PurchaseOrderView"           asp-route-reqId="102"
                                           class="btn btn-success btn-sm">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold">103</td>
                                <td>Charlie Ng</td>
                                <td>@DateTime.Now.AddHours(-3).ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge bg-warning text-dark">Pending</span></td>
                                <td class="text-center">
                                    <button class="btn btn-success btn-sm" disabled>
                                        <i class="bi bi-eye me-1"></i>View
                                    </button>
                                </td>
                            </tr>

                            <tr>
                                <td class="fw-semibold">104</td>
                                <td>Diana Koh</td>
                                <td>@DateTime.Now.AddDays(-5).ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge bg-danger">Rejected</span></td>
                                <td class="text-center">
                                    <button class="btn btn-success btn-sm" disabled>
                                        <i class="bi bi-eye me-1"></i>View
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>


}