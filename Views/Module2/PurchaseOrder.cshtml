@model ProRental.Controllers.PurchaseOrderPageViewModel

@{
    ViewData["Title"] = "Purchase Order";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Purchase Order Page</h2>
            <p class="text-muted mb-0">Create a purchase order from a replenishment request</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (Model.RequestId <= 0)
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="get" asp-controller="PurchaseOrderPage" asp-action="Index">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Replenishment Request ID</label>
                            <input type="number" name="reqId" class="form-control" min="1" required />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary">Load Request</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        return;
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Replenishment Request #@Model.RequestId</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2"><strong>Requested By:</strong> @Model.RequestedBy</div>
                    <div class="mb-2"><strong>Created At:</strong> @(Model.CreatedAt?.ToString("dd MMM yyyy HH:mm") ?? "-")</div>
                    <div class="mb-2"><strong>Status:</strong> @Model.Status</div>
                    <div class="mb-2"><strong>Remarks:</strong> @(string.IsNullOrWhiteSpace(Model.Remarks) ? "-" : Model.Remarks)</div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Requested Items</h5>
                </div>
                <div class="card-body">
                    @if (Model.Items.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Line Item ID</th>
                                        <th>Product ID</th>
                                        <th>Product Name</th>
                                        <th>Qty</th>
                                        <th>Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td>@item.LineItemId</td>
                                            <td>@item.ProductId</td>
                                            <td>@item.ProductName</td>
                                            <td>@item.Qty</td>
                                            <td>@(string.IsNullOrWhiteSpace(item.Remarks) ? "-" : item.Remarks)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">No items found for this request.</div>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Eligible Suppliers</h5>
                </div>
                <div class="card-body">
                    @if (Model.Suppliers.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Supplier ID</th>
                                        <th>Name</th>
                                        <th>Details</th>
                                        <th>Credit Period</th>
                                        <th>Avg Turnaround</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var supplier in Model.Suppliers)
                                    {
                                        <tr>
                                            <td>@supplier.SupplierId</td>
                                            <td>@supplier.SupplierName</td>
                                            <td>@supplier.Details</td>
                                            <td>@(supplier.CreditPeriod?.ToString() ?? "-")</td>
                                            <td>@(supplier.AvgTurnaroundTime?.ToString("0.##") ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">No verified suppliers found.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Confirm Purchase Order</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-controller="PurchaseOrderPage" asp-action="ConfirmPO">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reqId" value="@Model.RequestId" />

                        <div class="mb-3">
                            <label class="form-label">Select Supplier</label>
                            <select name="supplierId" class="form-select" required>
                                <option value="">-- Select Supplier --</option>
                                @foreach (var supplier in Model.Suppliers)
                                {
                                    <option value="@supplier.SupplierId">
                                        @supplier.SupplierName (ID: @supplier.SupplierId)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Expected Delivery Date</label>
                            <input type="date" name="expectedDeliveryDate" class="form-control" />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="confirmDetails" value="true" id="confirmDetails" />
                            <label class="form-check-label" for="confirmDetails">
                                I confirm the purchase order details are correct.
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Confirm Purchase Order</button>
                    </form>
                </div>
            </div>

            @if (Model.CreatedPoId.HasValue)
            {
                <div class="alert alert-success mt-3">
                    Created Purchase Order ID: <strong>@Model.CreatedPoId</strong>
                </div>
            }
        </div>
    </div>
</div>