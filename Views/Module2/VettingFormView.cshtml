@{
    ViewData["Title"] = "Submit Vetting";
}

<div class="container mt-4">
    <h2>Vetting Result</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @ViewBag.Error
        </div>
    }
    else if (ViewBag.VettingRecord != null && ViewBag.ReliabilityRating != null)
    {
        var record = ViewBag.VettingRecord;
        var rating = ViewBag.ReliabilityRating;

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Vetting Complete</h5>
                
                <p><strong>Supplier ID:</strong> @record.supplierid</p>
                <p><strong>Decision:</strong> 
                    <span class="badge @(record.decision == ProRental.Domain.Enums.VettingDecision.APPROVED ? "bg-success" : "bg-danger")">
                        @record.decision
                    </span>
                </p>
                <p><strong>Reliability Score:</strong> @rating.score.ToString("F2")</p>
                <p><strong>Rating Band:</strong> @rating.GetBand()</p>
                <p><strong>Notes:</strong> @record.notes</p>
                <p><strong>Vetted At:</strong> @record.vettedat</p>
            </div>
        </div>

        <div class="mt-3">
            <a href="@Url.Action("Dashboard", "VettingPage")" class="btn btn-primary">
                Back to Dashboard
            </a>
        </div>
    }
</div>
