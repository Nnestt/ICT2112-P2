@model List<ProRental.Domain.Entities.Clearancebatch>
@{
    ViewData["Title"] = "Clearance Batches";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-tags text-primary me-2"></i>Product Clearance</h2>
        <p class="text-muted small mb-0">Manage and schedule discounted equipment batches.</p>
    </div>
    <a asp-action="CreateBatch" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> New Batch
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="mt-3 text-muted fw-semibold">No clearance batches found.</p>
                <p class="text-muted small">Create your first batch to start moving older inventory.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Batch ID</th>
                            <th>Batch Name</th>
                            <th>Clearance Date</th>
                            <th>Created On</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var batch in Model)
                        {
                            var statusBadge = batch.GetStatus() switch
                            {
                                ProRental.Domain.Enums.ClearanceBatchStatus.SCHEDULED => "bg-warning text-dark",
                                ProRental.Domain.Enums.ClearanceBatchStatus.ACTIVE => "bg-success",
                                ProRental.Domain.Enums.ClearanceBatchStatus.CLOSED => "bg-secondary",
                                _ => "bg-info"
                            };

                            <tr>
                                <td class="ps-4 text-muted">#@batch.GetClearanceBatchId()</td>
                                <td class="fw-semibold">@batch.GetBatchName()</td>
                                <td>@(batch.GetClearanceDate()?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td>@batch.GetCreatedDate().ToString("dd MMM yyyy")</td>
                                <td><span class="badge @statusBadge rounded-pill px-3">@batch.GetStatus()</span></td>
                                <td class="text-end pe-4">
                                    <a asp-action="BatchDetails" asp-route-id="@batch.GetClearanceBatchId()"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        View
                                    </a>
                                    @if (batch.GetStatus() == ProRental.Domain.Enums.ClearanceBatchStatus.SCHEDULED)
                                    {
                                        <form asp-action="DeleteBatch" method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this batch?');">
                                            <input type="hidden" name="id" value="@batch.GetClearanceBatchId()" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle ms-1" title="Delete Batch">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>