@model IEnumerable<ProRental.Domain.Entities.Replenishmentrequest>
@{
    ViewData["Title"] = "Replenishment Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-box-seam me-2"></i>Replenishment Requests</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRequestModal">
        <i class="bi bi-plus-circle me-1"></i>New Request
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Requested By</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Completed At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RequestId</td>
                            <td>@item.RequestedBy</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case ProRental.Domain.Enums.ReplenishmentStatus.DRAFT:
                                        <span class="badge bg-secondary">Draft</span>
                                        break;
                                    case ProRental.Domain.Enums.ReplenishmentStatus.SUBMITTED:
                                        <span class="badge bg-primary">Submitted</span>
                                        break;
                                    case ProRental.Domain.Enums.ReplenishmentStatus.COMPLETED:
                                        <span class="badge bg-success">Completed</span>
                                        break;
                                    case ProRental.Domain.Enums.ReplenishmentStatus.CANCELLED:
                                        <span class="badge bg-danger">Cancelled</span>
                                        break;
                                }
                            </td>
                            <td>@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@item.CompletedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@item.RequestId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                                @if (item.CanEdit())
                                {
                                    <a asp-action="Form" asp-route-id="@item.RequestId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-2"></i>No replenishment requests found.
                            <a href="#" data-bs-toggle="modal" data-bs-target="#createRequestModal">Create one now</a>.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Request Modal -->
<div class="modal fade" id="createRequestModal" tabindex="-1" aria-labelledby="createRequestModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createRequestModalLabel">
                        <i class="bi bi-plus-circle me-2"></i>Create New Request
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="requestedBy" class="form-label">Staff ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="requestedBy" name="requestedBy"
                               placeholder="Enter your staff ID" required />
                        <div class="form-text">Enter the staff ID of the person creating this request.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Create Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
