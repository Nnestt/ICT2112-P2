@{
    ViewData["Title"] = "Staff Portal";
    var userName = Context.Session.GetString("UserName") ?? "Staff Member";
    var userRole = Context.Session.GetString("UserRole") ?? "STAFF";
    var isAdmin = userRole.Equals("ADMIN", StringComparison.OrdinalIgnoreCase);
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-9 col-lg-7">

        <!-- Success banner -->
        <div class="text-center mb-5">
            <div class="mb-3">
                <span class="badge @(isAdmin ? "bg-danger" : "bg-warning text-dark") px-3 py-2 fs-6">
                    <i class="bi bi-shield-fill-check me-1"></i>
                    @(isAdmin ? "Administrator" : "Staff") Session Active
                </span>
            </div>
            <h1 class="h2 fw-bold">Welcome back, @userName</h1>
            <p class="text-muted">You are signed in to the Staff &amp; Admin Portal.</p>
        </div>

        <!-- Quick-access cards -->
        <h5 class="fw-bold mb-3 mt-2 text-secondary border-bottom pb-2">Inventory Management Hub</h5>
        <div class="row g-3 mb-5">

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-primary"><i class="bi bi-collection"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Product Catalogue</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Manage product definitions and pricing.</p>
                            <a asp-controller="ProductCatalog" asp-action="Index" class="btn btn-sm btn-outline-primary w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-primary"><i class="bi bi-diagram-3"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Category Catalogue</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Organize equipment hierarchies.</p>
                            <a asp-controller="CategoryCatalog" asp-action="Index" class="btn btn-sm btn-outline-primary w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-primary"><i class="bi bi-box-seam"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Stock Management</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Track live physical inventory levels.</p>
                            <a asp-controller="StaffInventory" asp-action="DisplayInventoryList" class="btn btn-sm btn-outline-primary w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-warning"><i class="bi bi-calendar2-check"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Loan Management</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Process and dispatch rental orders.</p>
                            <a asp-controller="LoanList" asp-action="Index" class="btn btn-sm btn-outline-warning text-dark w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-danger"><i class="bi bi-arrow-return-left"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Return Pipeline</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Inspect and restock returned gear.</p>
                            <a asp-controller="ReturnProcessing" asp-action="DisplayReturnRequests" class="btn btn-sm btn-outline-danger w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-success"><i class="bi bi-tags"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Product Clearance</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Manage discounted end-of-life stock.</p>
                            <a asp-controller="Clearance" asp-action="Index" class="btn btn-sm btn-outline-success w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-info"><i class="bi bi-cart-plus"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Replenish Requests</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Review low-stock alerts and requests.</p>
                            <a asp-controller="ReplenishmentRequester" asp-action="List" class="btn btn-sm btn-outline-info w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-info"><i class="bi bi-receipt"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Purchase Orders</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Manage supplier purchase orders.</p>
                            <a asp-controller="PurchaseOrderPage" asp-action="Index" class="btn btn-sm btn-outline-info w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-secondary"><i class="bi bi-building-check"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Supplier Registry</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">View approved and trusted vendors.</p>
                            <a asp-controller="SupplierRegistryPage" asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-secondary"><i class="bi bi-shield-check"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Vetting Records</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Audit supplier vetting history.</p>
                            <a asp-controller="VettingPage" asp-action="Dashboard" class="btn btn-sm btn-outline-secondary w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3 text-dark"><i class="bi bi-clock-history"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Transaction Logs</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">System-wide audit trail and logs.</p>
                            <a asp-controller="TransactionLogging" asp-action="Index" class="btn btn-sm btn-outline-dark w-100">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex align-items-start gap-3 p-3">
                        <span class="fs-3" style="color: #6f42c1;"><i class="bi bi-bar-chart-line"></i></span>
                        <div>
                            <h6 class="fw-semibold mb-1">Analytics</h6>
                            <p class="text-muted small mb-2" style="line-height: 1.2;">Business intelligence and reporting.</p>
                            <a asp-controller="Analytics" asp-action="Index" class="btn btn-sm w-100" style="border-color: #6f42c1; color: #6f42c1;">Access</a>
                        </div>
                    </div>
                </div>
            </div>

            @if (isAdmin)
            {
                <h5 class="fw-bold mb-3 mt-4 text-danger border-bottom border-danger pb-2">Administrator Controls</h5>
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm border-danger border-opacity-25">
                        <div class="card-body d-flex align-items-start gap-3 p-3">
                            <span class="fs-3 text-danger"><i class="bi bi-people-fill"></i></span>
                            <div>
                                <h6 class="fw-semibold mb-1">User Management</h6>
                                <p class="text-muted small mb-2" style="line-height: 1.2;">Manage staff and customer accounts.</p>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-danger w-100">Access</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

            @if (isAdmin)
            {
                <div class="col-12 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm border-danger border-opacity-25">
                        <div class="card-body d-flex align-items-start gap-3 p-4">
                            <span class="fs-2 text-danger"><i class="bi bi-people-fill"></i></span>
                            <div>
                                <h6 class="fw-semibold mb-1">User Management</h6>
                                <p class="text-muted small mb-2">Manage staff and customer accounts.</p>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-danger">Go</a>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>

        <!-- Session info -->
        <div class="card border-0 bg-light">
            <div class="card-body px-4 py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="small text-muted">
                    <i class="bi bi-person-circle me-1"></i>
                    Logged in as <strong>@userName</strong>
                    &nbsp;·&nbsp;
                    <span class="badge @(isAdmin ? "bg-danger" : "bg-warning text-dark")">@userRole</span>
                </div>
                <form asp-controller="Module1" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>
